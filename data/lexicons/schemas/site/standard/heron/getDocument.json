{
  "lexicon": 1,
  "id": "site.standard.heron.getDocument",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a single document with full hydration.",
      "parameters": {
        "type": "params",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT URI of the document."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["document"],
          "properties": {
            "document": {
              "type": "ref",
              "ref": "site.standard.heron.defs#documentView"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound",
          "description": "The document does not exist."
        }
      ]
    }
  }
}
